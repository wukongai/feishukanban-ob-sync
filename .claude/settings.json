      "Edit(/Users/aim5/.claude/settings.json)",
      "Write(/Users/aim5/.claude/CLAUDE.md)",
      "Edit(/Users/aim5/.claude/CLAUDE.md)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/prevent-bash-compound.py",
            "timeout": 5
          }
        ]

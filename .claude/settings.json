      "Bash(git --no-pager show:*)",
      "Bash(git --no-pager status:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git tag:*)",
      "Bash(git stash:*)",
      "Bash(git push origin:*)",
      "Bash(git push gitee:*)",
      "Bash(git pull:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git -C:*)",

      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(wc:*)",
      "Bash(grep:*)",
      "Bash(grep -nF:*)",
      "Bash(find:*)",
